---
---

<section class="hero">
  <div class="hero-bg-image"></div>
  <div class="hero-overlay"></div>
  <div class="container">
    <div class="hero-content">
      <span class="section-label">AI Automation for Small Business</span>
      <h1>AI that handles the busywork<br/>so you can run your business.</h1>
      <p class="hero-desc">
        SmolOps connects to the tools you already use and removes the manual tasks slowing your
        business down. Emails, scheduling, follow-ups, paperwork, reporting. No new software
        to learn. No dashboards. Just less work.
      </p>
      <p class="hero-promise">
        Most SmolOps customers save 5 to 10 hours of admin work per week within the first month.
      </p>
      <div class="hero-actions">
        <a href="#audit" class="btn btn-primary">Get a Free AI Admin Audit</a>
        <a href="#how-it-works" class="btn btn-outline">See How It Works</a>
      </div>
      <div class="hero-trust">
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M16.67 5L7.5 14.17 3.33 10" stroke="#b8e6c8" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span>No software to install</span>
        </div>
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M16.67 5L7.5 14.17 3.33 10" stroke="#b8e6c8" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span>No replacing the tools you already use</span>
        </div>
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M16.67 5L7.5 14.17 3.33 10" stroke="#b8e6c8" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span>Just less admin work</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 160px 0 100px;
    overflow: hidden;
  }

  .hero-bg-image {
    position: absolute;
    inset: 0;
    background: url('/images/Small-business-owner-worried.jpg') center/cover no-repeat;
    filter: blur(1.5px);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      170deg,
      rgba(8, 32, 15, 0.82) 0%,
      rgba(18, 73, 35, 0.75) 50%,
      rgba(8, 32, 15, 0.85) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 720px;
  }

  .hero h1 {
    margin-bottom: 24px;
    color: var(--white);
  }

  .hero-desc {
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.8;
    margin-bottom: 20px;
    max-width: 600px;
  }

  .hero-promise {
    font-size: 1rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.95);
    margin-bottom: 36px;
    padding: 12px 20px;
    background: rgba(255, 255, 255, 0.1);
    border-left: 3px solid var(--gold);
    border-radius: 0 8px 8px 0;
    max-width: 540px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }

  .hero-actions .btn-outline {
    color: var(--white);
    border-color: rgba(255, 255, 255, 0.4);
  }

  .hero-actions .btn-outline:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.6);
    color: var(--white);
  }

  .hero-trust {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    color: rgba(255, 255, 255, 0.75);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 120px 0 72px;
    }
    .hero-actions {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
