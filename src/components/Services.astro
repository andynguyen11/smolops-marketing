<section id="where-we-help" class="services">
  <div class="container">
    <div class="text-center">
      <span class="section-label">Where SmolOps Helps</span>
      <h2 class="section-title">SmolOps removes the work that slows your business down.</h2>
      <p class="section-subtitle">
        AI agents handle the repetitive tasks you recognize all too well.
      </p>
    </div>

    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#124923" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
        </div>
        <h3>Customer Communication</h3>
        <ul class="service-tasks">
          <li>Answering common questions</li>
          <li>Scheduling appointments</li>
          <li>Confirming bookings</li>
          <li>Sending follow-ups</li>
          <li>Responding to inquiries</li>
        </ul>
      </div>

      <div class="service-card">
        <div class="service-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#124923" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
          </svg>
        </div>
        <h3>Operations</h3>
        <ul class="service-tasks">
          <li>Reading emails and creating tasks</li>
          <li>Summarizing conversations</li>
          <li>Preparing quotes and estimates</li>
          <li>Vendor ordering from sales data</li>
          <li>Inventory tracking via photo</li>
        </ul>
      </div>

      <div class="service-card">
        <div class="service-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#124923" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="20" x2="18" y2="10"/>
            <line x1="12" y1="20" x2="12" y2="4"/>
            <line x1="6" y1="20" x2="6" y2="14"/>
            <line x1="3" y1="20" x2="21" y2="20"/>
          </svg>
        </div>
        <h3>Reporting</h3>
        <ul class="service-tasks">
          <li>Daily and weekly business summaries</li>
          <li>Missed opportunity alerts</li>
          <li>Customer insights and trends</li>
          <li>Cash flow snapshots in plain English</li>
        </ul>
      </div>

      <div class="service-card">
        <div class="service-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#124923" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
        </div>
        <h3>Paperwork</h3>
        <ul class="service-tasks">
          <li>Extracting information from forms</li>
          <li>Preparing and organizing documents</li>
          <li>Invoice and receipt processing</li>
          <li>Filing and categorizing records</li>
        </ul>
      </div>

      <div class="service-card">
        <div class="service-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#124923" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <h3>Lead Generation</h3>
        <ul class="service-tasks">
          <li>Geo-targeted prospect discovery</li>
          <li>Contact info enrichment and verification</li>
          <li>Ready-to-use marketing lists</li>
          <li>Campaign draft generation</li>
        </ul>
      </div>

      <div class="service-card cta-card">
        <div class="service-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#124923" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="16"/>
            <line x1="8" y1="12" x2="16" y2="12"/>
          </svg>
        </div>
        <h3>Something else eating your time?</h3>
        <p>
          Every business is different. If there's a repetitive task you wish would just go away,
          there's a good chance we can automate it.
        </p>
        <a href="#audit" class="btn btn-outline" style="margin-top: 16px;">Tell Us About It</a>
      </div>
    </div>

    <div class="positioning-block">
      <p class="positioning-statement">SmolOps doesn't replace your software.<br/>It handles the work between your tools.</p>
    </div>
  </div>
</section>

<style>
  .services {
    background: linear-gradient(180deg, var(--white) 0%, var(--cream-light) 100%);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 56px;
  }

  .service-card {
    position: relative;
    background: var(--white);
    border: 1px solid rgba(18, 73, 35, 0.08);
    border-radius: 16px;
    padding: 36px 28px;
    transition: all 0.3s ease;
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(18, 73, 35, 0.1);
    border-color: rgba(18, 73, 35, 0.15);
  }

  .service-icon {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: var(--cream);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }

  .service-card h3 {
    margin-bottom: 16px;
    color: var(--green-dark);
  }

  .service-card p {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .service-tasks {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .service-tasks li {
    font-size: 15px;
    color: var(--text-muted);
    padding: 7px 0;
    padding-left: 22px;
    position: relative;
    line-height: 1.5;
  }

  .service-tasks li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green-mid);
    opacity: 0.4;
  }

  .cta-card {
    background: var(--cream);
    border-color: transparent;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .positioning-block {
    margin-top: 56px;
    text-align: center;
    padding: 40px;
    background: var(--green-dark);
    border-radius: 16px;
  }

  .positioning-statement {
    font-family: 'Fraunces', serif;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--cream);
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
    .positioning-block {
      padding: 28px 20px;
    }
    .positioning-statement {
      font-size: 1.15rem;
    }
  }
</style>
